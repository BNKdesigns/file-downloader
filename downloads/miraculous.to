.mto-visually-hidden{position:absolute!important;clip:rect(1px,1px,1px,1px);clip-path:inset(50%);width:1px;height:1px;overflow:hidden;white-space:nowrap;border:0;padding:0;margin:-1px}.mto-promo[hidden]{display:none}.mto-promo{position:fixed;inset:0;z-index:9999;display:grid;place-items:center}.mto-promo__backdrop{position:absolute;inset:0;background:rgb(0 0 0 / .55);backdrop-filter:saturate(120%) blur(4px);transition:opacity .25s ease}.mto-promo__sheet{position:relative;box-sizing:border-box;width:min(92vw,900px);max-height:90vh;overflow:auto;background:var(--mto-bg,#0b0c10);color:#fff;border-radius:20px;padding:18px 18px 12px;box-shadow:0 20px 60px rgb(0 0 0 / .35);transform:translateY(10px) scale(.98);opacity:0;transition:transform .25s ease,opacity .25s ease}@media (prefers-color-scheme:light){.mto-promo__sheet{--mto-bg:#111319}}.mto-promo.mto-open .mto-promo__sheet{transform:none;opacity:1}.mto-promo.mto-open .mto-promo__backdrop{opacity:1}.mto-promo__close{position:absolute;top:10px;right:12px;width:40px;height:40px;border-radius:999px;border:none;background:rgb(255 255 255 / .1);color:#fff;font-size:26px;line-height:1;cursor:pointer;transition:background .2s}.mto-promo__close:hover{background:rgb(255 255 255 / .18)}.mto-promo__link{display:block}.mto-promo__img{display:block;width:100%;height:auto;border-radius:14px;user-select:none;-webkit-user-drag:none}.mto-promo__footer{display:flex;justify-content:flex-end;gap:8px;margin-top:10px}.mto-promo__later{appearance:none;border:1px solid rgb(255 255 255 / .2);background:#fff0;color:#fff;border-radius:10px;padding:10px 14px;cursor:pointer;transition:background .2s,border-color .2s}.mto-promo__later:hover{background:rgb(255 255 255 / .08);border-color:rgb(255 255 255 / .35)}@media (max-width:520px){.mto-promo__sheet{padding:12px}.mto-promo__close{top:6px;right:8px}}@media (prefers-reduced-motion:reduce){.mto-promo__sheet,.mto-promo__backdrop{transition:none}}  */</style>

<script>/*
(function(){const MODAL_ID="promo-modal";const COOKIE_NAME="MTOPROMO3";const SHOW_AFTER_MS=800;const SUPPRESS_DAYS=1;const modal=document.getElementById(MODAL_ID);if(!modal)return;const sheet=modal.querySelector(".mto-promo__sheet");const closeEls=modal.querySelectorAll("[data-close]");const link=modal.querySelector(".mto-promo__link");let lastFocused=null;function setCookie(name,value,days){const d=new Date();d.setTime(d.getTime()+(days*24*60*60*1000));document.cookie=`${name}=${encodeURIComponent(value)}; expires=${d.toUTCString()}; path=/; domain=miraculous.to; secure; samesite=Strict`}
function getCookie(name){const m=document.cookie.match(new RegExp('(^| )'+name+'=([^;]+)'));return m?decodeURIComponent(m[2]):''}
function lockScroll(yes){document.documentElement.style.overflow=yes?"hidden":"";document.body.style.overflow=yes?"hidden":""}
function trapFocus(e){if(e.key!=="Tab")return;const focusables=sheet.querySelectorAll('a, button, [tabindex]:not([tabindex="-1"])');if(!focusables.length)return;const first=focusables[0],last=focusables[focusables.length-1];if(e.shiftKey&&document.activeElement===first){e.preventDefault();last.focus()}else if(!e.shiftKey&&document.activeElement===last){e.preventDefault();first.focus()}}
function openModal(){if(modal.hasAttribute("hidden")){modal.removeAttribute("hidden");modal.classList.add("mto-open");lastFocused=document.activeElement;lockScroll(!0);(link||sheet).focus?.();document.addEventListener("keydown",onKey);sheet.addEventListener("keydown",trapFocus)}}
function closeModal(){modal.classList.remove("mto-open");lockScroll(!1);modal.setAttribute("hidden","true");document.removeEventListener("keydown",onKey);sheet.removeEventListener("keydown",trapFocus);if(lastFocused&&lastFocused.focus)lastFocused.focus();setCookie(COOKIE_NAME,"1",SUPPRESS_DAYS)}
function onKey(e){if(e.key==="Escape"||e.key==="Esc"||e.key==="Backspace"){e.preventDefault();closeModal()}}
closeEls.forEach(el=>el.addEventListener("click",closeModal));modal.addEventListener("click",function(e){if(e.target&&e.target.dataset&&e.target.dataset.close)closeModal();});window.MTOpromo={open:openModal,close:closeModal};if(!getCookie(COOKIE_NAME)){window.addEventListener("load",()=>setTimeout(openModal,SHOW_AFTER_MS))}})() */
</script>

