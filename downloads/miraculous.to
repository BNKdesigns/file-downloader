<script>
  function toggleElement(element){
    var el = document.getElementById(element);
    if (!el) return;
    el.style.display = (el.style.display === 'none') ? '' : 'none';
  }

  var userTimezone = Intl.DateTimeFormat().resolvedOptions().timeZone;
  var userLang = navigator.language || navigator.userLanguage;
  var globalNewsLabels = {
    released: "Released",
    upcoming: "UPCOMING",
    delayed: "DELAYED",
    loading: "Loading...",
    plannedAirdate: "Planned airdate",
    delayedUntil: "Delayed until",
    timezone: "Time zone",
    day: "day(s)",
    hour: "hour(s)",
    minute: "minute(s)"  };

  function formatEpisodeDate(isoUtcString) {
    var episodeDate = new Date(isoUtcString);
    if (isNaN(episodeDate)) return '';
    var options = {
      timeZone: userTimezone,
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      hour: 'numeric',
      minute: 'numeric',
      hour12: false,
      timeZoneName: 'short'
    };
    return new Intl.DateTimeFormat(userLang, options).format(episodeDate);
  }

  function getLocalizedTimeZoneName(isoUtcString) {
    var episodeDate = new Date(isoUtcString);
    if (isNaN(episodeDate)) return '';
    var options = {
      timeZone: userTimezone,
      hour: 'numeric',
      minute: 'numeric',
      timeZoneName: 'longGeneric'
    };
    try {
      var parts = new Intl.DateTimeFormat(userLang, options).formatToParts(episodeDate);
      for (var i = 0; i < parts.length; i++) {
        if (parts[i].type === 'timeZoneName') return parts[i].value;
      }
    } catch (e) {}
    return userTimezone ? userTimezone.replace(/_/g, ' ') : '';
  }

  function setEpisodeDateAndZone(dateElementId, zoneElementId, isoUtcString) {
    var dateElement = document.getElementById(dateElementId);
    if (dateElement) {
      dateElement.textContent = formatEpisodeDate(isoUtcString) || globalNewsLabels.loading;
    }
    var zoneElement = document.getElementById(zoneElementId);
    if (zoneElement) {
      var zoneName = getLocalizedTimeZoneName(isoUtcString);
      zoneElement.textContent = zoneName ? globalNewsLabels.timezone + ': ' + zoneName : '';
    }
  }

  function updateCountdown(episodeId, isoUtcString, titleElement, isDelayed) {
    var episodeDate = new Date(isoUtcString);
    var countdownElement = document.getElementById('countdown-' + episodeId);
    if (isNaN(episodeDate)) {
      if (countdownElement) countdownElement.textContent = '---';
      return;
      if (cd) cd.textContent = '—';
      return;
    }

    var now = new Date();
    var diff = episodeDate.getTime() - now.getTime();

    if (diff <= 0) {
      countdownElement.innerHTML =
        '<span style="color: green; font-weight: bold;">' + globalNewsLabels.released + '</span>';
      if (titleElement) {
        var originalTitle = titleElement.getAttribute('data-original-title') || titleElement.textContent;
        titleElement.innerHTML = originalTitle + ' <span style="color:green; font-weight:bold;">' + globalNewsLabels.released + '</span>';
      }
    } else {
      var days = Math.floor(diff / 86400000);
      var hours = Math.floor((diff % 86400000) / 3600000);
      var minutes = Math.floor((diff % 3600000) / 60000);

      if (titleElement) {
        var originalTitle = titleElement.getAttribute('data-original-title') || titleElement.textContent;
        if (isDelayed || days < 7) {
          var badgeColor = isDelayed ? '#c77700' : 'red';
          var badgeText = isDelayed ? globalNewsLabels.delayed : globalNewsLabels.upcoming;
          titleElement.innerHTML = originalTitle + ' <span style="color:' + badgeColor + '; font-weight:bold;">' + badgeText + '</span>';
        } else {
          titleElement.innerHTML = originalTitle;
        }
      }

      var countdownColor = isDelayed ? '#c77700' : 'red';
      var countdownText = '<span style="color: ' + countdownColor + '; font-weight: bold;">'
        + days + ' ' + globalNewsLabels.day + ', '
        + hours + ' ' + globalNewsLabels.hour + ', '
        + minutes + ' ' + globalNewsLabels.minute + '</span>';

      countdownElement.innerHTML = countdownText;
    }

    setEpisodeDateAndZone('episode-date-' + episodeId, 'episode-zone-' + episodeId, isoUtcString);
    var plannedElement = document.getElementById('planned-date-' + episodeId);
    if (plannedElement && countdownElement) {
      var plannedIso = countdownElement.getAttribute('data-planned-date');
      setEpisodeDateAndZone('planned-date-' + episodeId, 'planned-zone-' + episodeId, plannedIso);
    }
  }

  function startCountdowns() {
    var episodes = document.querySelectorAll('[data-episode-date]');
    episodes.forEach(function(element) {
      var episodeId = element.getAttribute('data-episode-id');
      var isoUtc = element.getAttribute('data-episode-date');
      var isDelayed = element.getAttribute('data-episode-delayed') === '1';
      var titleElement = document.getElementById('title-' + episodeId);
      updateCountdown(episodeId, isoUtc, titleElement, isDelayed);
    });
  }

  document.addEventListener('DOMContentLoaded', function() {
    startCountdowns();
    setInterval(startCountdowns, 1000);
  });
</script>

  
