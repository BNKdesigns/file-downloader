    <!-- Search Modal -->
    <div class="search-modal" id="searchModal">
        <div class="search-container">
			<div class="search-info">Searching in titles, descriptions, and episode codes</div>
            <div class="search-header">
                <input type="text" class="search-input" id="searchInput" placeholder="Search episodes...">
                <button class="close-btn" id="closeBtn">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
                    </svg>
                </button>
            </div>
            
            <div class="search-options">
                <div class="lang-selector">
                    <label style="" for="languageSelect">Language:</label>
                    <select id="languageSelect">
                        <option value="all">All</option>
                        <option value="EN">English</option>
						<option value="BR">Brasil</option>
                        <option value="CZ">Czech</option>
                        <option value="DE">Deutsch</option>
                        <option value="ES">Español</option>
                        <option value="FR">Français</option>
						<option value="IT">Italiano</option>
                        <option value="LA">Latino</option>
                        <option value="PL">Polski</option>
                        <option value="PT">Portugal</option>
						<option value="RU">Pусский</option>
						<option value="TR">Türkçe</option>
                        <option value="KR">한국어</option>
                        <option value="JP">日本語</option>
                        <option value="AR">عربي</option>
                    </select>
                </div>
            </div>
            
            <div class="loading" id="loading">
                <div class="loading-spinner"></div>
            </div>
            
            <div class="search-results" id="searchResults">
                <!-- Results will be loaded here via AJAX -->
                <div class="no-results">Start typing to search for episodes</div>
            </div>
        </div>
    </div>

<script>$(document).ready(function(){let e=$("#searchBtn"),s=$("#searchModal"),t=$("#closeBtn"),a=$("#searchInput"),i=$("#languageSelect"),c=$("#searchResults"),o=$("#loading"),n=null;function l(){let e=a.val().trim();if(n&&clearTimeout(n),0===e.length){c.html('<div class="no-results">Start typing to search for episodes</div>');return}n=setTimeout(function(){!function e(s){let t=i.val();o.show(),c.hide(),$.ajax({url:"https://miraculous.to/search/search.php",method:"POST",data:{query:s,lang:t},dataType:"json",success:function(e){if(o.hide(),c.show(),0===e.length)c.html('<div class="no-results">No episodes found matching "'+s+'"</div>');else{let t="";e.forEach(function(e){let s=e.epcode.charAt(0),a=e.epcode.substring(1),i=`https://miraculous.to/${e.eplang.toLowerCase()}/watch?s=${s}&e=${a}`;t+=`
                        <div class="episode-card" data-url="${i}">
                            <img src="${e.epimgurl}" alt="${e.eptitle}" class="episode-image">
                            <div class="episode-info">
                                <h3 class="episode-title">${e.eptitle}</h3>
                                <p class="episode-desc">${e.epdesc}</p>
                                <div class="episode-meta">
                                    <span class="episode-code">Episode: ${e.epcode}</span>
                                    <span class="episode-lang">${e.eplang}</span>
                                </div>
                            </div>
                        </div>
                    `}),c.html(t)}},error:function(e,s,t){o.hide(),c.show(),c.html('<div class="no-results">Error occurred while searching. Please try again.</div>'),console.error("Search error:",t)}})}(e)},500)}e.on("click",function(){s.addClass("active"),setTimeout(function(){a.focus()},300)}),t.on("click",function(){s.removeClass("active"),a.val(""),c.html('<div class="no-results">Start typing to search for episodes</div>')}),$(document).keydown(function(e){"Escape"===e.key&&s.hasClass("active")&&t.click()}),a.on("input",function(){l()}),i.on("change",function(){a.val().trim().length>0&&l()}),$(document).on("click",".episode-card",function(){let e=$(this).data("url");e&&(window.location.href=e)})});</script>

