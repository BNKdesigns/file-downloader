<style>
.mto-card-link{display:block;text-decoration:none;color:inherit}
.mto-card-link:focus-visible{outline:3px solid #2563eb;outline-offset:4px;border-radius:22px}
.mto-episode-card{border-radius:14px;overflow:hidden;box-shadow:0 4px 18px rgba(0,0,0,.08);transition:transform .28s ease,box-shadow .28s ease;background:#fff}
.mto-card-link:hover .mto-episode-card,.mto-card-link:focus-visible .mto-episode-card{transform:translateY(-5px);box-shadow:0 14px 30px rgba(0,0,0,.18)}
.mto-episode-media{position:relative;overflow:hidden}
.mto-episode-image{width:100%;height:auto;display:block;aspect-ratio:16/9;object-fit:cover;transition:transform .35s ease}
.mto-card-link:hover .mto-episode-image,.mto-card-link:focus-visible .mto-episode-image{transform:scale(1.03)}
.mto-new-badge{position:absolute;top:10px;left:10px;z-index:3;background:#e50914;color:#fff;font-size:11px;font-weight:800;line-height:1;padding:7px 9px;border-radius:7px;letter-spacing:.4px;text-transform:uppercase}
.mto-episode-body{padding:10px 12px 12px}
.mto-episode-meta{display:block;color:#cf2d2d;font-size:10px;font-weight:700;letter-spacing:.35px;text-transform:uppercase;margin-bottom:4px}
.mto-episode-title{margin:0;font-size:20px;line-height:1.26;font-weight:700;color:#111;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.mto-card-progress{position:absolute;left:0;right:0;bottom:0;z-index:4;margin:0;pointer-events:none}
.mto-card-progress-track{--mto-progress:0%;position:relative;display:block;width:100%;height:4px;background:linear-gradient(90deg,rgba(255,255,255,.28),rgba(255,255,255,.12));border-radius:0;overflow:visible;box-shadow:none}
.mto-card-progress-fill{display:block;height:100%;width:0;background:linear-gradient(90deg,#ff3b30,#e50914);box-shadow:0 0 14px rgba(229,9,20,.45)}
.mto-card-progress-track::before{content:attr(data-progress-label);position:absolute;left:clamp(52px,var(--mto-progress),calc(100% - 52px));bottom:100%;margin-bottom:10px;padding:5px 11px;border-radius:999px;background:linear-gradient(145deg,rgba(24,24,32,.88),rgba(15,15,21,.96));border:1px solid rgba(255,255,255,.28);color:#fff;font-size:10px;font-weight:800;letter-spacing:.26px;white-space:nowrap;-webkit-backdrop-filter:blur(8px) saturate(130%);backdrop-filter:blur(8px) saturate(130%);transform:translate(-50%,6px) scale(.96);opacity:0;transition:opacity .24s ease,transform .24s ease;box-shadow:0 8px 22px rgba(0,0,0,.36),inset 0 1px 0 rgba(255,255,255,.12)}
.mto-card-progress-track::after{content:"";position:absolute;left:var(--mto-progress);top:50%;width:11px;height:11px;border-radius:50%;background:radial-gradient(circle at 35% 35%,#fff 0 35%,#ffd7d5 74%,#ffb1ab 100%);border:2px solid #ff3b30;transform:translate(-50%,-50%) scale(.62);opacity:0;transition:opacity .24s ease,transform .24s ease;box-shadow:0 0 0 4px rgba(255,59,48,.2),0 4px 12px rgba(0,0,0,.34)}
.mto-card-link:hover .mto-card-progress-track::before,.mto-card-link:focus-visible .mto-card-progress-track::before{opacity:1;transform:translate(-50%,0) scale(1)}
.mto-card-link:hover .mto-card-progress-track::after,.mto-card-link:focus-visible .mto-card-progress-track::after{opacity:1;transform:translate(-50%,-50%) scale(1);animation:mto-progress-marker-pulse 1.6s ease-in-out infinite}
@keyframes mto-progress-marker-pulse{0%,100%{box-shadow:0 0 0 3px rgba(255,59,48,.18),0 4px 12px rgba(0,0,0,.34)}50%{box-shadow:0 0 0 6px rgba(255,59,48,.3),0 6px 16px rgba(0,0,0,.42)}}
.mto-latest-col{margin-bottom:18px}
@media (max-width:767px){.mto-episode-title{font-size:16px}.mto-episode-body{padding:9px 10px 10px}}
</style>
        <script>
(function(){
    if (window.__mtoCardProgressBound) return;
    window.__mtoCardProgressBound = true;
    var MIN_VISIBLE_PROGRESS_SECONDS = 10;

    function readSavedTime(epcode, langCode){
        var base = 'miraculous_player_time_';
        var lang = String(langCode || '');
        var candidates = [
            base + epcode + '_' + lang,
            base + epcode + '_' + lang.toUpperCase(),
            base + epcode + '_' + lang.toLowerCase()
        ];

        for (var i = 0; i < candidates.length; i++) {
            var raw = null;
            try { raw = localStorage.getItem(candidates[i]); } catch (e) { raw = null; }
            if (raw !== null && raw !== '' && !isNaN(parseFloat(raw))) {
                return parseFloat(raw);
            }
        }

        return null;
    }

    function formatMinutesSeconds(totalSeconds){
        var safe = Math.max(0, Math.floor(Number(totalSeconds) || 0));
        var minutes = Math.floor(safe / 60);
        var seconds = safe % 60;
        return String(minutes) + ':' + String(seconds).padStart(2, '0');
    }

    function renderCardProgress(){
        var cards = document.querySelectorAll('.mto-card-link[data-epcode][data-lang]');
        if (!cards.length) return;

        cards.forEach(function(card){
            var epcode = card.getAttribute('data-epcode') || '';
            var lang = card.getAttribute('data-lang') || '';
            var expected = parseFloat(card.getAttribute('data-expected-seconds') || '1320');
            if (!epcode || !lang || !expected || isNaN(expected) || expected <= 0) return;

            var savedSeconds = readSavedTime(epcode, lang);
            var wrap = card.querySelector('[data-progress-wrap]');
            var track = card.querySelector('.mto-card-progress-track');
            var fill = card.querySelector('.mto-card-progress-fill');
            if (!wrap || !track || !fill) return;

            if (savedSeconds === null || savedSeconds < MIN_VISIBLE_PROGRESS_SECONDS) {
                wrap.hidden = true;
                fill.style.width = '0%';
                track.style.setProperty('--mto-progress', '0%');
                track.setAttribute('data-progress-label', '0:00');
                track.setAttribute('aria-valuenow', '0');
                return;
            }

            var pct = Math.max(1, Math.min(100, (savedSeconds / expected) * 100));
            var timeLabel = formatMinutesSeconds(savedSeconds);
            fill.style.width = pct.toFixed(1) + '%';
            track.style.setProperty('--mto-progress', pct.toFixed(1) + '%');
            track.setAttribute('data-progress-label', timeLabel);
            track.setAttribute('aria-valuenow', String(Math.round(pct)));
            track.setAttribute('aria-label', 'Watch progress ' + Math.round(pct) + '% at ' + timeLabel);
            wrap.hidden = false;
        });
    }

    document.addEventListener('DOMContentLoaded', renderCardProgress);
    window.addEventListener('load', function(){
        renderCardProgress();
        setTimeout(renderCardProgress, 250);
    });
    window.addEventListener('storage', renderCardProgress);
})();
</script>
